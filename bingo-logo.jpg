<!doctype html><html lang="zh-HK"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>BNI BINGO 紅黃綠燈平台</title><script src="vendor_xlsx.full.min.js"></script>
<style>
:root{--wine:#6f1737;--red:#db1835;--green:#26934a;--yellow:#e3b423;--black:#54545b;--ink:#201a1d;--muted:#746b70;--line:#e7dfe3;--bg:#f7f3f5}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--ink);font-family:"PingFang HK","Microsoft JhengHei",system-ui,sans-serif}button,input{font:inherit}header{background:#fff;border-bottom:3px solid var(--red);padding:10px 18px;display:flex;align-items:center;gap:14px;position:sticky;top:0;z-index:8}.logo{width:88px;height:66px;object-fit:contain;object-position:center;display:block;border-radius:4px}.brand b{display:block;font-size:18px}.brand span,.muted{font-size:12px;color:var(--muted)}.spacer{flex:1}.wrap{max-width:1050px;margin:auto;padding:18px}.card{background:#fff;border:1px solid var(--line);border-radius:16px;padding:18px;margin-bottom:14px;box-shadow:0 2px 8px #3810210b}.login{max-width:430px;margin:8vh auto}.login h1{font-size:25px;margin:0 0 5px}.field{width:100%;padding:12px;border:1px solid var(--line);border-radius:10px;margin:9px 0}.btn{border:0;background:var(--wine);color:#fff;padding:11px 15px;border-radius:10px;font-weight:750;cursor:pointer}.btn.light{background:#fff;color:var(--wine);border:1px solid var(--wine)}.wide{width:100%}.hide{display:none!important}.topline,.row{display:flex;gap:10px;align-items:center;flex-wrap:wrap}.topline h2{margin:0;font-size:20px}.tabs{display:flex;gap:7px;margin-bottom:14px}.tab{background:#fff;color:var(--wine);border:1px solid var(--line)}.tab.on{background:var(--wine);color:#fff}.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:9px}.kpi{text-align:center;color:#fff;border-radius:13px;padding:13px}.kpi strong{font-size:25px;display:block}.green{background:var(--green)}.yellow{background:var(--yellow);color:#514000}.red{background:var(--red)}.black{background:var(--black)}.search{padding:13px;border:1px solid var(--line);border-radius:12px;width:100%;font-size:16px}.member-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}.member{border:1px solid var(--line);background:#fff;border-radius:13px;padding:13px;cursor:pointer;text-align:left}.member:hover{border-color:var(--wine)}.pill{display:inline-block;color:#fff;border-radius:20px;padding:3px 9px;font-size:12px;font-weight:800}.member .score{font-size:24px;font-weight:850;float:right}.delta.up{color:var(--green)}.delta.down{color:var(--red)}.detail-head{display:grid;grid-template-columns:auto 1fr;gap:15px;align-items:center}.score-ring{width:96px;height:96px;border-radius:50%;display:grid;place-items:center;color:#fff;font-size:31px;font-weight:900}.breakdown{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}.metric{border:1px solid var(--line);border-radius:10px;padding:10px}.metric span{float:right;font-weight:850}.history{display:flex;gap:9px;overflow:auto}.month{min-width:150px;border:1px solid var(--line);border-radius:11px;padding:11px}.month strong{font-size:23px}.tips{padding-left:22px;line-height:1.7}.recap{white-space:pre-wrap;line-height:1.65;background:#fbf8fa;border:1px solid var(--line);padding:13px;border-radius:11px}.drop{border:2px dashed #cbbdc4;padding:22px;border-radius:13px;text-align:center;background:#fcfafb}.notice{padding:11px;border-radius:10px;background:#fff7dc;color:#725600;margin:10px 0}.ok{background:#e7f6ec;color:#176b32}.error{background:#fde8eb;color:#8b1125}.table-wrap{overflow:auto}table{border-collapse:collapse;width:100%;font-size:13px}th,td{padding:8px;border-bottom:1px solid var(--line);text-align:left;white-space:nowrap}footer{text-align:center;color:var(--muted);font-size:11px;padding:18px}@media(max-width:700px){.wrap{padding:12px}.member-grid{grid-template-columns:1fr}.kpis{grid-template-columns:repeat(2,1fr)}.breakdown{grid-template-columns:1fr}.brand span{display:none}.logo{width:66px;height:50px}.detail-head{grid-template-columns:1fr}.score-ring{width:82px;height:82px}}
.member-card-canvas{display:block;width:100%;max-width:720px;height:auto;margin:14px auto 0;border:1px solid var(--line);border-radius:12px;background:#fff}.card-actions{display:flex;gap:9px;justify-content:center;flex-wrap:wrap;margin-top:12px}
</style></head><body>
<header><img class="logo" src="data:image/jpeg;base64," alt="BNI BINGO"><div class="brand"><b>🚦 紅黃綠燈計算平台</b><span>BINGO Chapter · 目標安全線 75 分</span></div><div class="spacer"></div><button id="logout" class="btn light hide">登出</button></header>
<main class="wrap">
 <section id="login" class="card login"><h1>歡迎返嚟</h1><p class="muted">輸入 BINGO 共用密碼，即可查看完整會員表現。</p><input id="password" class="field" type="password" placeholder="共用密碼"><button id="memberLogin" class="btn wide">會員登入</button><button id="adminLogin" class="btn light wide" style="margin-top:8px">LT 管理員登入</button><div id="loginMsg"></div></section>
 <section id="app" class="hide"><div class="tabs"><button class="btn tab on" data-view="members">會員表現</button><button class="btn tab hide" id="adminTab" data-view="admin">LT 後台</button></div>
  <div id="membersView"><div class="card"><div class="topline"><div><h2>最新燈號總覽</h2><div id="period" class="muted"></div></div><div class="spacer"></div><select id="month" class="field" style="width:auto;margin:0"></select></div><div id="kpis" class="kpis" style="margin-top:14px"></div></div>
   <div class="card"><input id="search" class="search" placeholder="搜尋會員姓名…"><div id="memberGrid" class="member-grid" style="margin-top:12px"></div></div><div id="detail" class="hide"></div>
  </div>
  <div id="adminView" class="hide"><div class="card"><h2>上傳最新 Excel</h2><p class="muted">系統會重新計分、核對分項總和、比較上一期，再儲存 Excel 及發布會員資料。</p><label class="drop" for="excel"><b>選擇 Member Traffic Light Excel</b><br><span id="fileName" class="muted">.xlsx / .xls，最多 10MB</span></label><input id="excel" class="hide" type="file" accept=".xlsx,.xls"><div id="uploadMsg"></div><button id="publish" class="btn wide hide" style="margin-top:12px">核對後正式發布</button></div><div id="preview" class="card hide"></div></div>
 </section>
</main><footer>BNI BINGO Traffic Light · 資料經加密連線存放於私人資料庫</footer>
<script>
const API='https://qyufbsvrophwzcwlkppv.supabase.co/functions/v1/bni-api';let token='',role='',data={batches:[],members:[]},selectedFile=null,parsedReport=null;
const $=id=>document.getElementById(id), esc=s=>String(s??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
async function api(action,body={}){const r=await fetch(API,{method:'POST',headers:{'Content-Type':'application/json',...(token?{'x-bni-token':token}:{})},body:JSON.stringify({action,...body})});const j=await r.json();if(!r.ok)throw Error(j.error||'系統暫時未能處理');return j}
async function login(asRole){$('loginMsg').innerHTML='';try{const j=await api('login',{role:asRole,password:$('password').value});token=j.token;role=j.role;sessionStorage.setItem('bniSession',JSON.stringify({token,role,expires:j.expires_at}));await enter()}catch(e){$('loginMsg').innerHTML=`<div class="notice error">${esc(e.message)}</div>`}}
async function enter(){data=await api('history');$('login').classList.add('hide');$('app').classList.remove('hide');$('logout').classList.remove('hide');$('adminTab').classList.toggle('hide',role!=='admin');renderMonths()}
function batch(id){return data.batches.find(b=>b.id===id)} function rows(id){return data.members.filter(m=>m.batch_id===id)}
function renderMonths(){const m=$('month');m.innerHTML=data.batches.map((b,i)=>`<option value="${b.id}">${b.period_end}${i?'（歷史）':'（最新）'}</option>`).join('');if(data.batches.length)renderBatch(m.value)}
function lightName(l){return {green:'綠燈',yellow:'黃燈',red:'紅燈',black:'黑燈'}[l]||l} function delta(v){if(v==null)return '';const d=v;return `<span class="delta ${d>0?'up':d<0?'down':''}">${d>0?'▲ +':d<0?'▼ ':''}${d||'—'}</span>`}
function renderBatch(id){const b=batch(id), list=rows(id);$('period').textContent=b?`${b.period_start} 至 ${b.period_end} · ${list.length} 位會員`:'';const counts={green:0,yellow:0,red:0,black:0};list.forEach(x=>counts[x.light]++);$('kpis').innerHTML=Object.keys(counts).map(k=>`<div class="kpi ${k}"><strong>${counts[k]}</strong>${lightName(k)}</div>`).join('');renderList()}
function renderList(){const id=$('month').value,q=$('search').value.trim().toLowerCase(), list=rows(id).filter(x=>x.member_name.toLowerCase().includes(q));$('memberGrid').innerHTML=list.map(x=>{const prev=findPrevious(x.member_name,id),d=prev==null?null:x.total_score-prev;return `<button class="member" data-name="${esc(x.member_name)}"><span class="score">${x.total_score}</span><b>${esc(x.member_name)}</b><br><span class="pill ${x.light}">${lightName(x.light)}</span> ${delta(d)}</button>`}).join('')||'<p class="muted">找不到會員</p>';document.querySelectorAll('.member').forEach(x=>x.onclick=()=>showMember(x.dataset.name))}
function findPrevious(name,id){const ix=data.batches.findIndex(b=>b.id===id);for(let i=ix+1;i<data.batches.length;i++){const r=rows(data.batches[i].id).find(x=>x.member_name===name);if(r)return r.total_score}return null}
function showMember(name){const id=$('month').value,x=rows(id).find(r=>r.member_name===name);if(!x)return;const prev=findPrevious(name,id),d=prev==null?null:x.total_score-prev, metrics=[['缺席',x.absence_score,15],['遲到',x.lateness_score,10],['引薦',x.referral_score,20],['嘉賓',x.visitor_score,20],['1-2-1',x.one_to_one_score,10],['培訓',x.training_score,10],['生意',x.biz_give_score,15]];const hist=data.batches.map(b=>({b,x:rows(b.id).find(r=>r.member_name===name)})).filter(z=>z.x);$('detail').classList.remove('hide');$('detail').innerHTML=`<div class="card"><div class="detail-head"><div class="score-ring ${x.light}">${x.total_score}</div><div><h2 style="margin:0">${esc(name)} · ${lightName(x.light)}</h2><p>距離 75 分安全線：<b>${Math.max(0,75-x.total_score)} 分</b>　${delta(d)}</p><div class="history">${hist.map(z=>`<div class="month"><span class="muted">${z.b.period_end}</span><br><strong>${z.x.total_score}</strong> 分<br><span class="pill ${z.x.light}">${lightName(z.x.light)}</span></div>`).join('')}</div></div></div></div><div class="card"><h3>分項表現</h3><div class="breakdown">${metrics.map(m=>`<div class="metric">${m[0]}<span>${m[1]} / ${m[2]}</span></div>`).join('')}</div><h3>提升至安全綠燈建議</h3><ul class="tips">${(x.improvement_tips||[]).map(t=>`<li>${esc(t)}</li>`).join('')}</ul></div><div class="card"><div class="topline"><h3>會員燈號圖卡</h3><div class="spacer"></div><span class="muted">適合 WhatsApp 分享</span></div><canvas id="memberCard" class="member-card-canvas" width="1080" height="1600"></canvas><div class="card-actions"><button class="btn" id="downloadCard">下載 PNG</button><button class="btn light" id="shareCard">手機分享</button></div></div><div class="card"><div class="topline"><h3>個人化 WhatsApp Recap</h3><div class="spacer"></div><button class="btn" id="copyRecap">一鍵複製</button></div><div class="recap">${esc(x.recap_text||'')}</div></div>`;$('copyRecap').onclick=async()=>{await navigator.clipboard.writeText(x.recap_text||'');$('copyRecap').textContent='已複製 ✓'};requestAnimationFrame(()=>{drawMemberCard(x,batch(id),prev);$('downloadCard').onclick=()=>downloadCard(x.member_name);$('shareCard').onclick=()=>shareCard(x.member_name)});$('detail').scrollIntoView({behavior:'smooth'})}
function cardColor(light){return {green:'#26934a',yellow:'#e3b423',red:'#db1835',black:'#54545b'}[light]||'#54545b'}
function roundRect(ctx,x,y,w,h,r,fill){ctx.beginPath();ctx.roundRect(x,y,w,h,r);ctx.fillStyle=fill;ctx.fill()}
function canvasText(ctx,text,x,y,size=28,color='#201a1d',weight=400,align='left'){ctx.font=`${weight} ${size}px "PingFang HK","Microsoft JhengHei",Arial,sans-serif`;ctx.fillStyle=color;ctx.textAlign=align;ctx.fillText(text,x,y)}
function wrapCanvas(ctx,text,x,y,maxWidth,lineHeight,size=25,color='#3f383c'){const words=String(text).split('');let line='',cy=y;canvasText(ctx,'',x,cy,size,color);for(const ch of words){const test=line+ch;if(ctx.measureText(test).width>maxWidth&&line){ctx.fillText(line,x,cy);line=ch;cy+=lineHeight}else line=test}if(line)ctx.fillText(line,x,cy);return cy}
function drawMemberCard(x,b,prev){const c=$('memberCard'),ctx=c.getContext('2d'),W=c.width,H=c.height,col=cardColor(x.light);ctx.fillStyle='#fff';ctx.fillRect(0,0,W,H);const logo=document.querySelector('header .logo');if(logo&&logo.complete)ctx.drawImage(logo,48,34,135,100);canvasText(ctx,'紅黃綠燈燈號',1015,72,30,'#201a1d',800,'right');canvasText(ctx,`${b.period_start} – ${b.period_end}`,1015,113,22,'#777075',400,'right');ctx.fillStyle='#d7193f';ctx.fillRect(0,150,W,5);canvasText(ctx,x.member_name,48,225,45,'#171316',800);roundRect(ctx,820,185,195,62,31,col);canvasText(ctx,`${lightName(x.light)} · ${x.total_score}分`,918,226,27,x.light==='yellow'?'#554400':'#fff',800,'center');const change=prev==null?'未有上月紀錄':`上月 ${prev} ${x.total_score>prev?'▲'+(x.total_score-prev):x.total_score<prev?'▼'+(prev-x.total_score):'—'}`;canvasText(ctx,`總分 ${x.total_score}/100 · 週數 ${x.weeks} · 距安全線 ${Math.max(0,75-x.total_score)} 分 · ${change}`,48,275,23,'#777075');
 const items=[['培訓',x.training_score,10],['缺席',x.absence_score,15],['準時',x.lateness_score,10],['1-2-1',x.one_to_one_score,10],['引薦',x.referral_score,20],['Biz',x.biz_give_score,15],['嘉賓',x.visitor_score,20]],cx=540,cy=540,R=205,n=items.length;
 ctx.strokeStyle='#ddd9dc';ctx.lineWidth=2;for(let level=1;level<=5;level++){ctx.beginPath();for(let i=0;i<n;i++){const a=-Math.PI/2+i*2*Math.PI/n,rr=R*level/5,px=cx+Math.cos(a)*rr,py=cy+Math.sin(a)*rr;i?ctx.lineTo(px,py):ctx.moveTo(px,py)}ctx.closePath();ctx.stroke()}for(let i=0;i<n;i++){const a=-Math.PI/2+i*2*Math.PI/n;ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(cx+Math.cos(a)*R,cy+Math.sin(a)*R);ctx.stroke();canvasText(ctx,items[i][0],cx+Math.cos(a)*(R+40),cy+Math.sin(a)*(R+40)+8,22,'#6f686c',500,'center')}
 ctx.beginPath();items.forEach((m,i)=>{const a=-Math.PI/2+i*2*Math.PI/n,rr=R*(m[1]/m[2]),px=cx+Math.cos(a)*rr,py=cy+Math.sin(a)*rr;i?ctx.lineTo(px,py):ctx.moveTo(px,py)});ctx.closePath();ctx.fillStyle='rgba(38,147,74,.23)';ctx.fill();ctx.strokeStyle='#26934a';ctx.lineWidth=5;ctx.stroke();
 canvasText(ctx,'分項評分',48,800,31,'#201a1d',800);const bars=[['培訓 Training',x.training_score,10],['缺席 Absence',x.absence_score,15],['準時 On-time',x.lateness_score,10],['1–2–1',x.one_to_one_score,10],['引薦 Referral',x.referral_score,20],['Biz Give',x.biz_give_score,15],['嘉賓 Visitor',x.visitor_score,20]];bars.forEach((m,i)=>{const y=850+i*62;canvasText(ctx,m[0],48,y+25,23,'#2e292c',500);roundRect(ctx,315,y,570,22,11,'#eceaec');if(m[1])roundRect(ctx,315,y,570*m[1]/m[2],22,11,m[1]===m[2]?'#26934a':'#e3b423');canvasText(ctx,`${m[1]}/${m[2]}`,1005,y+23,23,'#201a1d',700,'right')});
 canvasText(ctx,'升燈貼士（75分安全線）',48,1325,30,'#201a1d',800);let ty=1370;(x.improvement_tips||[]).slice(0,3).forEach(t=>{ty=wrapCanvas(ctx,'• '+t,62,ty,930,34,23,'#3f383c')+42});ctx.strokeStyle='#e2dde0';ctx.beginPath();ctx.moveTo(48,1550);ctx.lineTo(1032,1550);ctx.stroke();canvasText(ctx,`根據 ${b.period_end} 或之前入機紀錄 · 綠燈標準 70 分 · 建議安全線 75 分`,48,1582,18,'#928a8f')}
function cardBlob(){return new Promise(ok=>$('memberCard').toBlob(ok,'image/png',1))}
function safeName(name){return String(name).replace(/[^a-zA-Z0-9\u3400-\u9fff_-]+/g,'_')}
async function downloadCard(name){const blob=await cardBlob(),a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=`BINGO-${safeName(name)}-燈號圖卡.png`;a.click();setTimeout(()=>URL.revokeObjectURL(a.href),3000)}
async function shareCard(name){const blob=await cardBlob(),file=new File([blob],`BINGO-${safeName(name)}-燈號圖卡.png`,{type:'image/png'});if(navigator.canShare&&navigator.canShare({files:[file]})){await navigator.share({title:`${name} BINGO 燈號圖卡`,files:[file]})}else downloadCard(name)}
function scoreLight(n){return n>=70?'green':n>=50?'yellow':n>=30?'red':'black'}
function makeTips(r,total){const w=Math.max(+r[16]||1,1),out=[];if((+r[10]||0)/w<.75)out.push(`增加 ${Math.max(1,Math.ceil(.75*w)-(+r[10]||0))} 位嘉賓，提升嘉賓分數`);if((+r[8]||0)/w<1.5)out.push(`增加 ${Math.max(1,Math.ceil(1.5*w)-(+r[8]||0))} 個引薦，提升引薦分數`);if((+r[11]||0)/w<1)out.push(`增加 ${Math.max(1,w-(+r[11]||0))} 次 1-2-1`);if((+r[12]||0)<2)out.push(`增加 ${2-(+r[12]||0)} 次培訓`);return out.slice(0,3).length?out.slice(0,3):['保持現有表現，繼續以 75 分安全線為目標']}
async function parseExcel(file){const wb=XLSX.read(await file.arrayBuffer(),{type:'array',cellDates:true}),ws=wb.Sheets['Traffic Light Report']||wb.Sheets[wb.SheetNames[0]],a=XLSX.utils.sheet_to_json(ws,{header:1,raw:true,defval:null});if(!a[1]||!String(a[1][0]).match(/\d{4}-\d{2}-\d{2}/g))throw Error('未能辨認報告日期');const dates=String(a[1][0]).match(/\d{4}-\d{2}-\d{2}/g),latest=data.batches[0],prevMap=new Map((latest?rows(latest.id):[]).map(x=>[x.member_name,x.total_score]));const members=a.slice(5).filter(r=>typeof r[0]==='number'&&r[1]).map(r=>{const total=+(r[24]??r[15]??0),name=String(r[1]).trim(),tips=makeTips(r,total),need=Math.max(0,75-total);return {member_name:name,total_score:total,light:scoreLight(total),weeks:+r[16]||0,absence_score:+r[17]||0,lateness_score:+r[18]||0,referral_score:+r[19]||0,visitor_score:+r[20]||0,one_to_one_score:+r[21]||0,training_score:+r[22]||0,biz_give_score:+r[23]||0,previous_score:prevMap.get(name)??null,improvement_tips:tips,recap_text:`Hello ${name},\n以下係根據 ${dates[1]} 或之前的入機記錄作出的專屬燈號。\n\n總分：${total} 分；距離 75 分安全線需要增加 ${need} 分。\n${tips.map(t=>'• '+t).join('\n')}\n\n今屆非常重視大家的生意，一齊全民衝燈，創造成果！`,raw_metrics:{P:r[3],A:r[4],L:r[5],M:r[6],S:r[7],G:r[8],R:r[9],V:r[10],one_to_one:r[11],T:r[12],biz_give:r[13],pls_percent:r[14]}}});const bad=members.filter(m=>m.total_score!==m.absence_score+m.lateness_score+m.referral_score+m.visitor_score+m.one_to_one_score+m.training_score+m.biz_give_score);if(bad.length)throw Error(`發現 ${bad.length} 位會員分項總和不符：${bad.slice(0,3).map(x=>x.member_name).join('、')}`);return {period_start:dates[0],period_end:dates[1],source_filename:file.name,members}}
async function b64(file){return new Promise((ok,no)=>{const r=new FileReader;r.onload=()=>ok(String(r.result).split(',')[1]);r.onerror=no;r.readAsDataURL(file)})}
$('memberLogin').onclick=()=>login('member');$('adminLogin').onclick=()=>login('admin');$('password').onkeydown=e=>{if(e.key==='Enter')login('member')};$('month').onchange=()=>{renderBatch($('month').value);$('detail').classList.add('hide')};$('search').oninput=renderList;
document.querySelectorAll('.tab').forEach(t=>t.onclick=()=>{document.querySelectorAll('.tab').forEach(x=>x.classList.remove('on'));t.classList.add('on');$('membersView').classList.toggle('hide',t.dataset.view!=='members');$('adminView').classList.toggle('hide',t.dataset.view!=='admin')});
$('excel').onchange=async e=>{selectedFile=e.target.files[0];if(!selectedFile)return;$('fileName').textContent=selectedFile.name;$('uploadMsg').innerHTML='<div class="notice">正在核對公式及會員資料…</div>';try{parsedReport=await parseExcel(selectedFile);$('uploadMsg').innerHTML='<div class="notice ok">核對完成：分項總和正確，可以發布。</div>';$('publish').classList.remove('hide');$('preview').classList.remove('hide');$('preview').innerHTML=`<h3>發布預覽</h3><p><b>${parsedReport.period_end}</b> · ${parsedReport.members.length} 位會員</p><div class="table-wrap"><table><tr><th>會員</th><th>總分</th><th>上期</th><th>燈號</th></tr>${parsedReport.members.slice(0,12).map(m=>`<tr><td>${esc(m.member_name)}</td><td>${m.total_score}</td><td>${m.previous_score??'—'}</td><td>${lightName(m.light)}</td></tr>`).join('')}</table></div>`}catch(err){$('uploadMsg').innerHTML=`<div class="notice error">${esc(err.message)}</div>`;$('publish').classList.add('hide')}};
$('publish').onclick=async()=>{if(!parsedReport||!selectedFile)return;$('publish').disabled=true;$('publish').textContent='發布中…';try{const source_file_base64=await b64(selectedFile);await api('publish',{report:parsedReport,source_file_base64});data=await api('history');renderMonths();$('uploadMsg').innerHTML='<div class="notice ok">發布成功，會員頁已更新。</div>';$('publish').classList.add('hide')}catch(e){$('uploadMsg').innerHTML=`<div class="notice error">${esc(e.message)}</div>`}finally{$('publish').disabled=false;$('publish').textContent='核對後正式發布'}};
$('logout').onclick=async()=>{try{await api('logout')}catch{}sessionStorage.clear();location.reload()};
try{const s=JSON.parse(sessionStorage.getItem('bniSession'));if(s&&new Date(s.expires)>new Date()){token=s.token;role=s.role;enter().catch(()=>sessionStorage.clear())}}catch{}
</script></body></html>

