{
  "name": "bni-traffic-light-cloudflare",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:assets": "node scripts/sync-assets.mjs",
    "dev": "npm run sync:assets && wrangler dev",
    "typecheck": "tsc --noEmit",
    "test": "node ../tests/green_path_logic.test.js",
    "dry-run": "npm run sync:assets && wrangler deploy --dry-run",
    "deploy": "npm run sync:assets && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "export:current": "node scripts/export-current.mjs",
    "make:import": "node scripts/import-json.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260722.0",
    "typescript": "^5.9.2",
    "wrangler": "^4.0.0"
  }
}
